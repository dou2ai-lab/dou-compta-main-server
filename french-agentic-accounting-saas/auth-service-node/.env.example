# Auth Service - Node.js
# Copy to .env and set values. Use same PostgreSQL as project (see README).

PORT=8001
NODE_ENV=development

# JWT (use long random strings in production)
JWT_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars

# Optional: token TTL
# JWT_ACCESS_EXPIRES_IN=30m
# JWT_REFRESH_EXPIRES_IN=7d

# PostgreSQL: same instance as main app; use same DB (tables are prefixed auth_*)
# Example with Docker Postgres on port 5433:
DATABASE_URL=postgresql://dou_user:dou_password123@localhost:5433/dou_expense_audit
