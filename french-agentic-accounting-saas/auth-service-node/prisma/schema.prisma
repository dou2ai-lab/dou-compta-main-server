// Prisma schema for Dou Auth Service
// GDPR: minimal fields; no unnecessary PII. EU/French best practices.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Default tenant for single-tenant or default org (GDPR: one tenant per company)
model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @map("name")
  slug      String   @unique @map("slug")
  status    String   @default("active") @map("status")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]
  @@map("auth_tenants")
}

// User: only fields required for auth and display (data minimization)
model User {
  id             String   @id @default(uuid()) @db.Uuid
  email          String   @unique @map("email")
  passwordHash   String   @map("password_hash")
  firstName      String?  @map("first_name")
  lastName       String?  @map("last_name")
  isEmailVerified Boolean @default(false) @map("is_email_verified")
  status         String   @default("active") @map("status")
  tenantId       String   @map("tenant_id") @db.Uuid
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@index([email])
  @@index([tenantId])
  @@map("auth_users")
}

// Password reset: token stored hashed with expiry (e.g. 1 hour)
model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String  @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("auth_password_reset_tokens")
}

// Refresh tokens: stored server-side for revocation (EU best practice)
model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String  @unique @map("token_hash") // hash of token, never store plaintext
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("auth_refresh_tokens")
}
