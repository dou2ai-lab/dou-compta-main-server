# Copy to .env.local and set values.

# Optional: LibreTranslate for dynamic translation (FR/EN).
# Default: https://libretranslate.com (no API key required for many instances).
# LIBRETRANSLATE_API_URL=http://localhost:5000
# LIBRETRANSLATE_API_KEY=optional-if-your-instance-requires-it

# Backend API URLs (if different from defaults)
# NEXT_PUBLIC_EXPENSE_API_URL=http://localhost:8002
# NEXT_PUBLIC_FILE_API_URL=http://localhost:8005
