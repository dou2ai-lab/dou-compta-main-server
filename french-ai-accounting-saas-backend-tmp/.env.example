# Backend services (Auth, Expense, File, etc.)
# Copy to .env and set values.

# Database (required)
# Docker Postgres (infrastructure/docker-compose.yml): use localhost and host port 5433
DATABASE_URL=postgresql://dou_user:dou_password123@localhost:5433/dou_expense_audit

# Receipt upload (File Service): use the SAME value as auth-service-node/.env JWT_SECRET
JWT_SECRET=paste-same-value-as-auth-service-node-JWT_SECRET-here
# NODE_JWT_SECRET=paste-same-value-as-auth-service-node-JWT_SECRET-here

# Storage (File Service)
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# STORAGE_BUCKET=dou-receipts-dev
# STORAGE_REGION=eu-west-1
LOCAL_STORAGE_PATH=/tmp/dou-receipts

# Encryption (set false for local dev)
ENCRYPTION_ENABLED=false
# ENCRYPTION_MASTER_KEY=your-32-byte-base64-key-for-dev

# Message Queue (document ingestion events)
MESSAGE_QUEUE_PROVIDER=rabbitmq
# RABBITMQ_URL=amqp://dou_user:dou_password@localhost:5672/
# Or Kafka:
# MESSAGE_QUEUE_PROVIDER=kafka
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# OCR Provider (tesseract, google_document_ai, azure_form_recognizer)
OCR_PROVIDER=tesseract
# Google Document AI (EU: use eu location)
# GOOGLE_PROJECT_ID=
# GOOGLE_LOCATION=eu
# GOOGLE_PROCESSOR_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Azure Form Recognizer (EU: westeurope)
# AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_KEY=
# AZURE_REGION=westeurope

# LLM (for post-processing OCR text - merchant, date, total, VAT extraction)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=models/gemini-2.0-flash
