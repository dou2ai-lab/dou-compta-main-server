FROM pgvector/pgvector:pg14
COPY pg_hba.conf /tmp/pg_hba.conf
COPY docker-entrypoint-initdb.d/99-trust-all.sh /docker-entrypoint-initdb.d/99-trust-all.sh
# Strip CRLF so script runs on Linux (Windows host may save CRLF)
RUN sed -i 's/\r$//' /docker-entrypoint-initdb.d/99-trust-all.sh && chmod +x /docker-entrypoint-initdb.d/99-trust-all.sh
