# Copy to `infrastructure/.env` (or export env vars) for local docker-compose runs.
#
# IMPORTANT:
# - Do NOT commit real secrets.
# - If any secrets were ever committed to git history, rotate them immediately.

# Auth
JWT_SECRET=change-me

# LLM providers
GEMINI_API_KEY=
OPENAI_API_KEY=

# Email (report service notifications)
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=


