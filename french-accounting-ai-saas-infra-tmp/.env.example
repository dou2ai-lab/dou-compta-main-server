# =============================================
# DouCompta Phase 1 — Environment Variables
# Copy this file to .env and fill in your values
# =============================================

# PostgreSQL
POSTGRES_DB=doucompta
POSTGRES_USER=dou_user
POSTGRES_PASSWORD=dou_password123
DATABASE_URL=postgresql://dou_user:dou_password123@localhost:5433/doucompta

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO (S3-compatible storage)
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=doucompta-files

# Application
SECRET_KEY=change-me-in-production-use-long-random-string
DEBUG=true

# Backend (used by email ingestion service)
BACKEND_URL=http://localhost:8000

# Email Ingestion (IMAP)
IMAP_HOST=imap.example.com
IMAP_PORT=993
EMAIL_ADDRESS=doucompta@example.com
EMAIL_PASSWORD=change-me

# File service / Receipt extract pipeline (docker-compose file-service)
NEXT_PUBLIC_FILE_API_URL=http://localhost:8005
OCR_PROVIDER=tesseract
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-2.0-flash

